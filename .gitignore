# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.env
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
# AppleDouble metadata files (resource forks) — keep scoped to `app/` to avoid
# ignoring intentionally-named dot-underscore files (e.g. `._config.js`).
app/**/._*
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Backend test resources — may contain local DB credentials, never commit
backend/src/test/resources/application.yml

# Local build/run logs
backend_log.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
public/tutorials/*.mp4
.env.local
